<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="vtol_tricopter">
    <pose>0 0 0.2 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.016</ixx><iyy>0.016</iyy><izz>0.032</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.4 0.1 0.1</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
    </link>

    <link name="tilt_1">
      <pose>0.15 0.2 0 0 0 0</pose>
      <visual name="v1"><geometry><cylinder><radius>0.02</radius><length>0.1</length></cylinder></geometry></visual>
    </link>
    <joint name="tilt_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>tilt_1</child>
      <axis>
        <xyz>0 1 0</xyz> <limit><lower>-1.57</lower><upper>1.57</upper></limit>
      </axis>
    </joint>

    <link name="tilt_2">
      <pose>0.15 -0.2 0 0 0 0</pose>
      <visual name="v2"><geometry><cylinder><radius>0.02</radius><length>0.1</length></cylinder></geometry></visual>
    </link>
    <joint name="tilt_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>tilt_2</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper></limit>
      </axis>
    </joint>

    <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <lock_step>1</lock_step>
      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>
      
      <control channel="0"><jointName>tilt_1_joint</jointName><type>VELOCITY</type></control>
      <control channel="1"><jointName>tilt_2_joint</jointName><type>VELOCITY</type></control>
      <control channel="4"><jointName>tilt_1_joint</jointName><type>POSITION</type></control>
      <control channel="5"><jointName>tilt_2_joint</jointName><type>POSITION</type></control>
    </plugin>

    <link name="down_cam_link">
      <pose>0 0 -0.1 0 1.5708 0</pose>
      <sensor name="down_cam" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>1280</width><height>720</height></image>
        </camera>
        <plugin name="GstCameraPlugin" filename="GstCameraPlugin">
          <udp_host>127.0.0.1</udp_host>
          <udp_port>5601</udp_port>
        </plugin>
      </sensor>
    </link>
    <joint name="down_cam_joint" type="fixed">
      <parent>base_link</parent>
      <child>down_cam_link</child>
    </joint>
  </model>
</sdf>